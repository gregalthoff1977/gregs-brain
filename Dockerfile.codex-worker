FROM node:20-bookworm

WORKDIR /app

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex

COPY . /app

RUN chmod +x /app/scripts/run_codex_maintenance.sh

CMD ["/app/scripts/run_codex_maintenance.sh"]
